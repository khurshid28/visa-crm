// Prisma schema — Visa CRM
// MySQL. `npm run db:push` bilan jadvallarni yaratasiz.

generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "debian-openssl-3.0.x"]
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

// Bir martalik Excel yuklash = bitta "Guruh" (group).
model Group {
  id          Int          @id @default(autoincrement())
  name        String // masalan "Guruh 1" yoki fayl nomi
  note        String?      @db.Text
  status      GroupStatus  @default(PENDING)
  fileName    String?

  // Slot (vaqt oynasi) — web va bot orqali boshqariladi.
  slotOpenAt  DateTime? // slot ochilgan/ochiladigan vaqt
  slotCloseAt DateTime? // slot yopilgan/yopiladigan vaqt

  // Guruh pauzada bo'lsa — slot ochilsa ham bu guruh arizachilari
  // GO (buyurtma) navbatiga qo'shilmaydi.
  paused      Boolean      @default(false)

  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
  applicants  Applicant[]
  runs        RunAttempt[]
  imports     ImportLog[]
  statusLogs  GroupStatusLog[]

  @@index([status])
}

// Guruh bo'yicha har bir "run" (urinish) — run-1, run-2, ...
// register/order bosqichlari bo'yicha natijalar shu yerda saqlanadi.
model RunAttempt {
  id        Int      @id @default(autoincrement())
  groupId   Int
  group     Group    @relation(fields: [groupId], references: [id], onDelete: Cascade)
  attempt   Int      @default(1) // guruh ichidagi tartib raqami (run-1, run-2...)
  stage     String // "register" | "order"
  total     Int      @default(0)
  succeeded Int      @default(0)
  failed    Int      @default(0)
  source    String   @default("web") // "web" | "bot"
  note      String?  @db.Text
  createdAt DateTime @default(now())

  @@index([groupId])
}

// Excel/CSV import tarixi — kim qachon nechta arizachi yukladi.
model ImportLog {
  id        Int      @id @default(autoincrement())
  groupId   Int
  group     Group    @relation(fields: [groupId], references: [id], onDelete: Cascade)
  fileName  String? // yuklangan fayl nomi
  filePath  String? // diskda saqlangan asl fayl yo'li (uploads/imports/...)
  fileSize  Int? // fayl hajmi (bayt)
  total     Int      @default(0) // fayldagi yaroqli qatorlar
  imported  Int      @default(0) // qo'shilgan arizachilar
  complete  Int      @default(0) // to'liq ma'lumotli
  reused    Int      @default(0) // mavjud shaxs (boshqa guruhdan)
  skipped   Int      @default(0) // guruhda allaqachon bor — tashlandi
  source    String   @default("web") // "web" | "bot"
  userId    String? // Telegram user id (bot orqali bo'lsa)
  username  String? // @username (bot orqali bo'lsa)
  createdAt DateTime @default(now())

  @@index([groupId])
  @@index([createdAt])
}

// Guruh status o'zgarishlari tarixi — hech qaysi o'zgarish yo'qolmaydi.
model GroupStatusLog {
  id         Int      @id @default(autoincrement())
  groupId    Int
  group      Group    @relation(fields: [groupId], references: [id], onDelete: Cascade)
  fromStatus String? // oldingi status (birinchi marta bo'lsa null)
  toStatus   String // yangi status
  source     String   @default("web") // "web" | "bot" | "system"
  note       String?  @db.Text // sabab / izoh
  userId     String? // Telegram user id (bot orqali bo'lsa)
  username   String? // @username (bot orqali bo'lsa)
  createdAt  DateTime @default(now())

  @@index([groupId])
  @@index([createdAt])
}

// Telegram bot xabarlari tarixi — kim, qachon, nima yozdi va javob nima edi.
model BotMessage {
  id        Int      @id @default(autoincrement())
  chatId    String // Telegram chat id
  userId    String? // Telegram user id
  username  String? // @username (bo'lishi shart emas)
  firstName String? // foydalanuvchi ismi
  isAdmin   Boolean  @default(false) // admin chat'idanmi
  type      String   @default("text") // text | command | document | photo | other
  text      String?  @db.Text // xabar matni / komanda
  success   Boolean  @default(true) // qayta ishlash muvaffaqiyatlimi
  response  String?  @db.Text // botning javobi yoki xato matni
  createdAt DateTime @default(now())

  @@index([chatId])
  @@index([userId])
  @@index([createdAt])
}

// Excel ichidagi har bir qator = bitta arizachi.
model Applicant {
  id               Int             @id @default(autoincrement())
  groupId          Int
  group            Group           @relation(fields: [groupId], references: [id], onDelete: Cascade)

  // Umumiy shaxs (passport bo'yicha) — bir odam ko'p guruhda bo'lishi mumkin.
  personId         Int?
  person           Person?         @relation(fields: [personId], references: [id], onDelete: SetNull)

  // VFS template maydonlari
  surname          String
  name             String
  passportNumber   String
  nationality      String?
  gender           String?
  birthdate        String? // dd.mm.yyyy ko'rinishida saqlanadi
  passportValidity String? // dd.mm.yyyy
  phone            String?
  email            String? // Excel'dagi e-mail (ko'pincha bo'sh)
  source           String?
  subcategory      String?

  // Excel'dagi qo'shimcha ustunlar
  city             String?
  category         String?
  price            String?
  bookDateFrom     String?
  bookDateTo       String?
  regDaysBefore    String?
  groupLabel       String? // Excel'dagi "Group (not required)" ustuni

  // Tizim tomonidan generatsiya qilinadi
  generatedEmail   String? // masalan ism.familiya{id}@uzbekviza.uz
  generatedPassword String? // tizim (gmail/VFS) paroli — email yonida saqlanadi
  complete         Boolean @default(false) // required maydonlar to'liqmi

  // Jarayon holati
  status           ApplicantStatus @default(NEW)
  appointmentRef   String? // booking natijasidagi raqam
  pdfPath          String? // saqlangan PDF yo'li
  passportPhoto    String? // yuklangan passport rasmi yo'li (/passports/..)
  resultNote       String?         @db.Text

  // Persistent profil (har bir userning gmail sessiyasi shu kalit bo'yicha saqlanadi)
  profileKey       String? // sanitize qilingan gmail (cookies/localStorage shu profilda)

  // Ro'yxatdan o'tish (1-bosqich) vaqt va urinishlar
  registerStartedAt  DateTime?
  registerFinishedAt DateTime?
  registerDurationMs Int? // oxirgi register necha ms davom etdi
  registerAttempts   Int      @default(0)

  // Buyurtma berish (2-bosqich) vaqt va urinishlar
  orderStartedAt   DateTime?
  orderFinishedAt  DateTime?
  orderDurationMs  Int? // oxirgi order necha ms davom etdi
  orderAttempts    Int      @default(0)

  // Email aktivatsiya (register'dan keyin gmail'ga kelgan linkni ochish).
  // Aktivatsiya tugamaguncha register to'liq hisoblanmaydi.
  activationStatus String?   @default("none") // none | pending | activated | failed
  activationEmailTo String? // qaysi email manziliga aktivatsiya xati keldi
  activationLink   String?   @db.Text // gmail'dan topilgan aktivatsiya linki
  activationSentAt DateTime? // xat kelgan/aniqlangan vaqt
  activatedAt      DateTime? // link ochilib aktivlashtirilgan vaqt

  createdAt        DateTime        @default(now())
  updatedAt        DateTime        @updatedAt

  changeLogs       ApplicantChangeLog[]
  automationLogs   AutomationLog[]

  @@index([groupId])
  @@index([status])
  @@index([passportNumber])
}

// Har bir avtomatlashtirish urinishi (register/order) — chiroyli log uchun.
// Kim, qachon, qaysi bosqich, nechanchi urinish, qancha vaqt, natija.
model AutomationLog {
  id            Int        @id @default(autoincrement())
  applicantId   Int?
  applicant     Applicant? @relation(fields: [applicantId], references: [id], onDelete: SetNull)
  groupId       Int?
  stage         String // "register" | "order" | "slot"
  attempt       Int        @default(1) // nechanchi urinish (1..3)
  ok            Boolean    @default(false)
  durationMs    Int        @default(0)
  note          String?    @db.Text
  url           String?    @db.Text // urinish boshlangan (target) URL
  finalUrl      String?    @db.Text // urinish oxirida brauzer turgan URL
  visitedUrls   String?    @db.Text // ochilgan barcha URL'lar (newline bilan)
  workerProfile String? // qaysi worker/profil bajardi
  startedAt     DateTime   @default(now())
  finishedAt    DateTime   @default(now())
  createdAt     DateTime   @default(now())

  @@index([applicantId])
  @@index([groupId])
  @@index([stage])
  @@index([createdAt])
}

// Arizachi (user/mijoz) o'zgarishlari tarixi — kim, qachon, nimani o'zgartirdi.
// Tahrir, status o'zgarishi va o'chirish ham yoziladi. Hech narsa yo'qolmaydi.
model ApplicantChangeLog {
  id          Int        @id @default(autoincrement())
  applicantId Int?
  applicant   Applicant? @relation(fields: [applicantId], references: [id], onDelete: SetNull)
  groupId     Int? // qaysi guruhdagi arizachi (o'chirilgandan keyin ham qoladi)
  action      String // "edit" | "status" | "delete"
  fields      String?    @db.Text // o'zgargan maydonlar ro'yxati (vergul bilan)
  before      String?    @db.Text // o'zgarishdan oldingi qiymatlar (JSON)
  after       String?    @db.Text // o'zgarishdan keyingi qiymatlar (JSON)
  actor       String? // o'zgartirgan admin (username) yoki "bot"
  source      String     @default("web") // "web" | "bot" | "system"
  createdAt   DateTime   @default(now())

  @@index([applicantId])
  @@index([groupId])
  @@index([createdAt])
}

// Umumiy shaxs — passport raqami bo'yicha noyob. Bir odam ko'p guruhda
// (ko'p Applicant yozuvi) ishtirok etishi mumkin, lekin shaxs bitta.
// Passport rasmi shu yerda (bazada) saqlanadi — ochiq turadi, faqat
// tashqi tizimga yuborilganda ishlatiladi.
model Person {
  id               Int          @id @default(autoincrement())
  passportNumber   String       @unique
  surname          String
  name             String
  nationality      String?
  gender           String?
  birthdate        String?
  passportValidity String?
  phone            String?

  // Standartlashtirilgan passport rasmi (Google standarti: 600x600 JPEG)
  photo            Bytes?       @db.LongBlob
  photoMime        String?      @default("image/jpeg")

  applicants       Applicant[]
  createdAt        DateTime     @default(now())
  updatedAt        DateTime     @updatedAt
}

enum GroupStatus {
  PENDING // yuklandi, kutilyapti
  READY // tekshirildi, tayyor
  SLOT_OPEN // slot ochiq
  SLOT_CLOSED // slot yopiq
  BOOKING // zakas qilinyapti
  DONE // tugadi
  ARCHIVED // arxivlangan (qo'lda)
}

enum ApplicantStatus {
  NEW // yangi yuklangan
  EDITED // tahrirlangan
  BOOKING // zakas qilinyapti (eski)
  REGISTERED // ro'yxatdan o'tgan (1-bosqich)
  ORDERED // buyurtma berilgan (2-bosqich)
  BOOKED // band qilindi (PDF bor)
  FAILED // xatolik
  ARCHIVED // arxivlangan (qo'lda)
}

// Global slot monitoring holati — butun tizimga bitta (singleton, id=1).
// Avval uploads/slot-monitor-state.json faylida edi; endi bazada,
// shu sababli holat va loglar bir joyda, ishonchli saqlanadi.
model SlotMonitor {
  id                  Int       @id @default(1)
  active              Boolean   @default(false)
  paused              Boolean   @default(false)
  slotAt              DateTime? // belgilangan slot vaqti
  windowMinutes       Int       @default(10)
  registerLeadMinutes Int       @default(5)
  lastCheckAt         DateTime? // oxirgi tekshiruv vaqti
  lastMessage         String    @default("Monitoring to'xtagan")
  openedAt            DateTime? // joriy sessiyada slot ochiq topilgan vaqt
  updatedAt           DateTime  @updatedAt
}

// Slot voqealari tarixi — qachon, qanday o'zgardi, nechta user o'tdi.
// "bitta slot hammaga ta'sir qiladi" — shuning uchun har bir o'zgarish loglanadi.
model SlotEvent {
  id          Int       @id @default(autoincrement())
  type        String // configure | open | close | pause | go | stop | check | expired
  slotAt      DateTime? // o'sha paytdagi belgilangan slot vaqti
  closeAt     DateTime? // yopilish vaqti (bo'lsa)
  message     String?   @db.Text
  usersQueued Int       @default(0) // order queue'ga yuborilgan userlar
  usersDone   Int       @default(0) // bajarilgan (ordered) userlar
  groupsCount Int       @default(0) // shu voqeada qatnashgan guruhlar soni
  durationSec Int? // slot qancha vaqt ochiq turdi (close/expired uchun)
  source      String    @default("system") // web | bot | system
  username    String? // o'zgartirgan admin (bo'lsa)
  createdAt   DateTime  @default(now())

  @@index([type])
  @@index([createdAt])
}
