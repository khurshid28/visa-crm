// Prisma schema — Visa CRM
// MySQL. `npm run db:push` bilan jadvallarni yaratasiz.

generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "debian-openssl-3.0.x"]
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

// Bir martalik Excel yuklash = bitta "Guruh" (group).
model Group {
  id          Int          @id @default(autoincrement())
  name        String // masalan "Guruh 1" yoki fayl nomi
  note        String?      @db.Text
  status      GroupStatus  @default(PENDING)
  fileName    String?

  // Slot (vaqt oynasi) — web va bot orqali boshqariladi.
  slotOpenAt  DateTime? // slot ochilgan/ochiladigan vaqt
  slotCloseAt DateTime? // slot yopilgan/yopiladigan vaqt

  // Guruh qaysi slotga (yo'nalishga) bog'langan. Slot ochilsa shu guruh
  // arizachilari navbatga qo'shiladi. Bog'lanmagan bo'lsa — null.
  slotId      Int?
  slot        Slot?        @relation(fields: [slotId], references: [id], onDelete: SetNull)

  // Guruh pauzada bo'lsa — slot ochilsa ham bu guruh arizachilari
  // GO (buyurtma) navbatiga qo'shilmaydi.
  paused      Boolean      @default(false)

  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
  applicants  Applicant[]
  runs        RunAttempt[]
  imports     ImportLog[]
  statusLogs  GroupStatusLog[]

  @@index([status])
  @@index([slotId])
}

// Guruh bo'yicha har bir "run" (urinish) — run-1, run-2, ...
// register/order bosqichlari bo'yicha natijalar shu yerda saqlanadi.
model RunAttempt {
  id        Int      @id @default(autoincrement())
  groupId   Int
  group     Group    @relation(fields: [groupId], references: [id], onDelete: Cascade)
  attempt   Int      @default(1) // guruh ichidagi tartib raqami (run-1, run-2...)
  stage     String // "register" | "order"
  total     Int      @default(0)
  succeeded Int      @default(0)
  failed    Int      @default(0)
  source    String   @default("web") // "web" | "bot"
  note      String?  @db.Text
  createdAt DateTime @default(now())

  @@index([groupId])
}

// Excel/CSV import tarixi — kim qachon nechta arizachi yukladi.
model ImportLog {
  id        Int      @id @default(autoincrement())
  groupId   Int
  group     Group    @relation(fields: [groupId], references: [id], onDelete: Cascade)
  fileName  String? // yuklangan fayl nomi
  filePath  String? // diskda saqlangan asl fayl yo'li (uploads/imports/...)
  fileSize  Int? // fayl hajmi (bayt)
  total     Int      @default(0) // fayldagi yaroqli qatorlar
  imported  Int      @default(0) // qo'shilgan arizachilar
  complete  Int      @default(0) // to'liq ma'lumotli
  reused    Int      @default(0) // mavjud shaxs (boshqa guruhdan)
  skipped   Int      @default(0) // guruhda allaqachon bor — tashlandi
  source    String   @default("web") // "web" | "bot"
  userId    String? // Telegram user id (bot orqali bo'lsa)
  username  String? // @username (bot orqali bo'lsa)
  createdAt DateTime @default(now())

  @@index([groupId])
  @@index([createdAt])
}

// Guruh status o'zgarishlari tarixi — hech qaysi o'zgarish yo'qolmaydi.
model GroupStatusLog {
  id         Int      @id @default(autoincrement())
  groupId    Int
  group      Group    @relation(fields: [groupId], references: [id], onDelete: Cascade)
  fromStatus String? // oldingi status (birinchi marta bo'lsa null)
  toStatus   String // yangi status
  source     String   @default("web") // "web" | "bot" | "system"
  note       String?  @db.Text // sabab / izoh
  userId     String? // Telegram user id (bot orqali bo'lsa)
  username   String? // @username (bot orqali bo'lsa)
  createdAt  DateTime @default(now())

  @@index([groupId])
  @@index([createdAt])
}

// Telegram bot xabarlari tarixi — kim, qachon, nima yozdi va javob nima edi.
model BotMessage {
  id        Int      @id @default(autoincrement())
  chatId    String // Telegram chat id
  userId    String? // Telegram user id
  username  String? // @username (bo'lishi shart emas)
  firstName String? // foydalanuvchi ismi
  isAdmin   Boolean  @default(false) // admin chat'idanmi
  type      String   @default("text") // text | command | document | photo | other
  text      String?  @db.Text // xabar matni / komanda
  success   Boolean  @default(true) // qayta ishlash muvaffaqiyatlimi
  response  String?  @db.Text // botning javobi yoki xato matni
  createdAt DateTime @default(now())

  @@index([chatId])
  @@index([userId])
  @@index([createdAt])
}

// Excel ichidagi har bir qator = bitta arizachi.
model Applicant {
  id               Int             @id @default(autoincrement())
  groupId          Int
  group            Group           @relation(fields: [groupId], references: [id], onDelete: Cascade)

  // Umumiy shaxs (passport bo'yicha) — bir odam ko'p guruhda bo'lishi mumkin.
  personId         Int?
  person           Person?         @relation(fields: [personId], references: [id], onDelete: SetNull)

  // VFS template maydonlari
  surname          String
  name             String
  passportNumber   String
  nationality      String?
  gender           String?
  birthdate        String? // dd.mm.yyyy ko'rinishida saqlanadi
  passportValidity String? // dd.mm.yyyy
  phone            String?
  email            String? // Excel'dagi e-mail (ko'pincha bo'sh)
  source           String?
  subcategory      String?

  // Excel'dagi qo'shimcha ustunlar
  city             String?
  category         String?
  price            String?
  bookDateFrom     String?
  bookDateTo       String?
  regDaysBefore    String?
  groupLabel       String? // Excel'dagi "Group (not required)" ustuni

  // Tizim tomonidan generatsiya qilinadi
  generatedEmail   String? // masalan ism.familiya{id}@uzbekviza.uz
  generatedPassword String? // tizim (gmail/VFS) paroli — email yonida saqlanadi
  complete         Boolean @default(false) // required maydonlar to'liqmi

  // Jarayon holati
  status           ApplicantStatus @default(NEW)
  appointmentRef   String? // booking natijasidagi raqam
  pdfPath          String? // saqlangan PDF yo'li
  passportPhoto    String? // yuklangan passport rasmi yo'li (/passports/..)
  resultNote       String?         @db.Text

  // Persistent profil (har bir userning gmail sessiyasi shu kalit bo'yicha saqlanadi)
  profileKey       String? // sanitize qilingan gmail (cookies/localStorage shu profilda)

  // Ro'yxatdan o'tish (1-bosqich) vaqt va urinishlar
  registerStartedAt  DateTime?
  registerFinishedAt DateTime?
  registerDurationMs Int? // oxirgi register necha ms davom etdi
  registerAttempts   Int      @default(0)

  // Buyurtma berish (2-bosqich) vaqt va urinishlar
  orderStartedAt   DateTime?
  orderFinishedAt  DateTime?
  orderDurationMs  Int? // oxirgi order necha ms davom etdi
  orderAttempts    Int      @default(0)

  // Email aktivatsiya (register'dan keyin gmail'ga kelgan linkni ochish).
  // Aktivatsiya tugamaguncha register to'liq hisoblanmaydi.
  activationStatus String?   @default("none") // none | pending | activated | failed
  activationEmailTo String? // qaysi email manziliga aktivatsiya xati keldi
  activationLink   String?   @db.Text // gmail'dan topilgan aktivatsiya linki
  activationSentAt DateTime? // xat kelgan/aniqlangan vaqt
  activatedAt      DateTime? // link ochilib aktivlashtirilgan vaqt

  createdAt        DateTime        @default(now())
  updatedAt        DateTime        @updatedAt

  changeLogs       ApplicantChangeLog[]
  automationLogs   AutomationLog[]

  @@index([groupId])
  @@index([status])
  @@index([passportNumber])
}

// Har bir avtomatlashtirish urinishi (register/order) — chiroyli log uchun.
// Kim, qachon, qaysi bosqich, nechanchi urinish, qancha vaqt, natija.
model AutomationLog {
  id            Int        @id @default(autoincrement())
  applicantId   Int?
  applicant     Applicant? @relation(fields: [applicantId], references: [id], onDelete: SetNull)
  groupId       Int?
  stage         String // "register" | "login" | "order" | "activation" | "slot"
  attempt       Int        @default(1) // nechanchi urinish (1..3)
  ok            Boolean    @default(false)
  durationMs    Int        @default(0)
  note          String?    @db.Text
  url           String?    @db.Text // urinish boshlangan (target) URL
  finalUrl      String?    @db.Text // urinish oxirida brauzer turgan URL
  visitedUrls   String?    @db.Text // ochilgan barcha URL'lar (newline bilan)
  workerProfile String? // qaysi worker/profil bajardi
  proxyServer   String? // ulangan proxy gateway (host:port)
  proxyCountry  String? // proxy davlati (uz/kz)
  proxySession  String? // sticky session id (qaysi user IP'si)
  exitIp        String? // proxy orqali chiqqan tashqi IP
  statusCode    Int? // asosiy sahifa HTTP status kodi
  navMs         Int? // sahifa ochilish davomiyligi (ochilgan - kelgan)
  pageError     String?    @db.Text // chrome web ochganda chiqqan xatolar
  requestedAt   DateTime? // "kelgan": navigatsiya boshlangan vaqt
  openedAt      DateTime? // "ochilgan": sahifa ochilgan/javob kelgan vaqt
  startedAt     DateTime   @default(now())
  finishedAt    DateTime   @default(now())
  createdAt     DateTime   @default(now())

  @@index([applicantId])
  @@index([groupId])
  @@index([stage])
  @@index([createdAt])
}

// Arizachi (user/mijoz) o'zgarishlari tarixi — kim, qachon, nimani o'zgartirdi.
// Tahrir, status o'zgarishi va o'chirish ham yoziladi. Hech narsa yo'qolmaydi.
model ApplicantChangeLog {
  id          Int        @id @default(autoincrement())
  applicantId Int?
  applicant   Applicant? @relation(fields: [applicantId], references: [id], onDelete: SetNull)
  groupId     Int? // qaysi guruhdagi arizachi (o'chirilgandan keyin ham qoladi)
  action      String // "edit" | "status" | "delete"
  fields      String?    @db.Text // o'zgargan maydonlar ro'yxati (vergul bilan)
  before      String?    @db.Text // o'zgarishdan oldingi qiymatlar (JSON)
  after       String?    @db.Text // o'zgarishdan keyingi qiymatlar (JSON)
  actor       String? // o'zgartirgan admin (username) yoki "bot"
  source      String     @default("web") // "web" | "bot" | "system"
  createdAt   DateTime   @default(now())

  @@index([applicantId])
  @@index([groupId])
  @@index([createdAt])
}

// Umumiy shaxs — passport raqami bo'yicha noyob. Bir odam ko'p guruhda
// (ko'p Applicant yozuvi) ishtirok etishi mumkin, lekin shaxs bitta.
// Passport rasmi shu yerda (bazada) saqlanadi — ochiq turadi, faqat
// tashqi tizimga yuborilganda ishlatiladi.
model Person {
  id               Int          @id @default(autoincrement())
  passportNumber   String       @unique
  surname          String
  name             String
  nationality      String?
  gender           String?
  birthdate        String?
  passportValidity String?
  phone            String?

  // Standartlashtirilgan passport rasmi (Google standarti: 600x600 JPEG)
  photo            Bytes?       @db.LongBlob
  photoMime        String?      @default("image/jpeg")

  applicants       Applicant[]
  createdAt        DateTime     @default(now())
  updatedAt        DateTime     @updatedAt
}

enum GroupStatus {
  PENDING // yuklandi, kutilyapti
  READY // tekshirildi, tayyor
  SLOT_OPEN // slot ochiq
  SLOT_CLOSED // slot yopiq
  BOOKING // zakas qilinyapti
  DONE // tugadi
  ARCHIVED // arxivlangan (qo'lda)
}

enum ApplicantStatus {
  NEW // yangi yuklangan
  EDITED // tahrirlangan
  BOOKING // zakas qilinyapti (eski)
  REGISTERED // ro'yxatdan o'tgan (1-bosqich)
  ORDERED // buyurtma berilgan (2-bosqich)
  BOOKED // band qilindi (PDF bor)
  FAILED // xatolik
  ARCHIVED // arxivlangan (qo'lda)
}

// Global slot monitoring holati — butun tizimga bitta (singleton, id=1).
// Ko'p slotli tizim — har bir slot bitta yo'nalish (qayerdan -> qayerga).
// Guruhlar shu slotga bog'lanadi. Yaratish super-parol bilan himoyalangan.
model Slot {
  id                  Int       @id @default(autoincrement())
  name                String // masalan "Latviya tongi" yoki yo'nalish nomi
  fromCountry         String    @default("UZB") // ISO3 — qayerdan
  toCountry           String    @default("LVA") // ISO3 — qayerga
  slotAt              DateTime? // belgilangan slot vaqti
  windowMinutes       Int       @default(10)
  registerLeadMinutes Int       @default(5)
  // VFS appointment-detail sahifasidagi tanlovlar (kalendar tekshiruvi uchun).
  // Bo'sh bo'lsa .env default (BOOKING_CALENDAR_*) ishlatiladi.
  centre              String? // "Choose your Application Centre" (masalan: VFS GLOBAL SERVICES UBKN)
  category            String? // "Choose your appointment category" (masalan: Latvia Long Stay/Visa D)
  subCategory         String? // "Choose your sub-category" (masalan: Cargo drivers (Visa D) Uzbek, Turkmen)
  active              Boolean   @default(false)
  paused              Boolean   @default(false)
  lastCheckAt         DateTime? // oxirgi tekshiruv vaqti
  lastMessage         String    @default("Yaratildi")
  openedAt            DateTime? // joriy sessiyada slot ochiq topilgan vaqt
  lastShotPath        String? // oxirgi tekshiruv skrinshoti (uploads/slot-monitor/...)
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt
  groups              Group[]

  @@index([active])
}

// Avval uploads/slot-monitor-state.json faylida edi; endi bazada,
// shu sababli holat va loglar bir joyda, ishonchli saqlanadi.
model SlotMonitor {
  id                  Int       @id @default(1)
  active              Boolean   @default(false)
  paused              Boolean   @default(false)
  slotAt              DateTime? // belgilangan slot vaqti
  windowMinutes       Int       @default(10)
  registerLeadMinutes Int       @default(5)
  lastCheckAt         DateTime? // oxirgi tekshiruv vaqti
  lastMessage         String    @default("Monitoring to'xtagan")
  openedAt            DateTime? // joriy sessiyada slot ochiq topilgan vaqt
  updatedAt           DateTime  @updatedAt
}

// Slot voqealari tarixi — qachon, qanday o'zgardi, nechta user o'tdi.
// "bitta slot hammaga ta'sir qiladi" — shuning uchun har bir o'zgarish loglanadi.
model SlotEvent {
  id          Int       @id @default(autoincrement())
  slotId      Int? // qaysi slot (ko'p slotli tizimda). null = global monitor
  type        String // configure | open | close | pause | go | stop | check | expired
  slotAt      DateTime? // o'sha paytdagi belgilangan slot vaqti
  closeAt     DateTime? // yopilish vaqti (bo'lsa)
  message     String?   @db.Text
  usersQueued Int       @default(0) // order queue'ga yuborilgan userlar
  usersDone   Int       @default(0) // bajarilgan (ordered) userlar
  groupsCount Int       @default(0) // shu voqeada qatnashgan guruhlar soni
  durationSec Int? // slot qancha vaqt ochiq turdi (close/expired uchun)
  source      String    @default("system") // web | bot | system
  username    String? // o'zgartirgan admin (bo'lsa)
  createdAt   DateTime  @default(now())

  @@index([type])
  @@index([createdAt])
  @@index([slotId])
}

// Ichki tiketlar (ish so'rovlari / muammolar) — 2-3 admin yuritadi.
// Har bir tiket: matn, status, manba (system/web/bot), hashteglar,
// bog'langan obyektlar (slot/guruh/user/hujjat), biriktirilgan fayllar
// (rasm/hujjat, 10 tagacha) va xabarlar zanjiri (todo uslubida yoziladi).
// Arxivlangach asosiy ro'yxatdan yo'qoladi, "Arxiv" bo'limida qoladi.
model Ticket {
  id          Int                @id @default(autoincrement())
  title       String
  body        String?            @db.Text
  source      String             @default("system") // system | web | bot
  status      String             @default("OPEN") // OPEN | PROGRESS | WAITING | DONE
  tags        String?            @db.Text // hashteglar: "#slot #shoshilinch"
  archived    Boolean            @default(false)
  author      String? // yaratgan admin (username)
  createdAt   DateTime           @default(now())
  updatedAt   DateTime           @updatedAt
  attachments TicketAttachment[]
  entries     TicketEntry[]
  refs        TicketRef[]

  @@index([archived])
  @@index([status])
  @@index([createdAt])
}

// Tiket xabari (zanjir) — bitta tiketga 2-3 ta matn ketma-ket yoziladi.
// Har bir xabarning o'z fayllari (rasm/hujjat) bo'lishi mumkin.
model TicketEntry {
  id          Int                @id @default(autoincrement())
  ticketId    Int
  ticket      Ticket             @relation(fields: [ticketId], references: [id], onDelete: Cascade)
  body        String?            @db.Text
  author      String? // yozgan admin (username)
  createdAt   DateTime           @default(now())
  attachments TicketAttachment[]

  @@index([ticketId])
}

// Tiket fayli — rasm yoki hujjat. Bazada (LongBlob) saqlanadi, /api orqali
// ko'rsatiladi/yuklab olinadi. Tiketga yoki uning bir xabariga bog'lanadi.
model TicketAttachment {
  id        Int          @id @default(autoincrement())
  ticketId  Int
  ticket    Ticket       @relation(fields: [ticketId], references: [id], onDelete: Cascade)
  entryId   Int? // null = tiketning o'zida; bo'lsa — shu xabarga tegishli
  entry     TicketEntry? @relation(fields: [entryId], references: [id], onDelete: Cascade)
  data      Bytes        @db.LongBlob
  mime      String       @default("image/png")
  name      String?
  size      Int          @default(0) // bayt
  kind      String       @default("image") // image | file
  createdAt DateTime     @default(now())

  @@index([ticketId])
  @@index([entryId])
}

// Tiketga bog'langan obyekt (slot/guruh/user/hujjat) — @# mention uslubida.
model TicketRef {
  id        Int      @id @default(autoincrement())
  ticketId  Int
  ticket    Ticket   @relation(fields: [ticketId], references: [id], onDelete: Cascade)
  kind      String // slot | group | user | document
  refId     Int
  label     String
  createdAt DateTime @default(now())

  @@index([ticketId])
}

// Worker (avtomatlashtirish ishchisi) — order-worker pool'idagi har bir "lane".
// Default 10 ta yaratiladi (lib/workers.ts ensureSeed). Admin bularni boshqaradi:
//   - 8 tasini active qilish (faqat shuncha worker ishlaydi);
//   - yana 10 qo'shib 20 ta qilish (addWorkers).
// "Faol" (active) workerlar soni = bir vaqtda parallel ishlaydigan brauzerlar soni.
//
// CPU BILAN BOG'LIQLIK (muhim): har bir faol worker = 1 ta haqiqiy Chrome (CPU va
// RAM jihatidan og'ir). Shuning uchun parallel ishlay oladigan workerlar soni
// PROTSESSOR yadrolariga bog'liq. lib/workers.ts: recommendedMax = yadrolar soni *
// WORKER_PER_CPU (.env, default 2). Faol workerlar shu limitdan oshsa — ular
// navbatga turadi, hammasi sekinlashadi (CPU yetishmaydi). Ko'proq parallel kerak
// bo'lsa — kuchliroq CPU (ko'proq yadro) qo'shish kerak.
model Worker {
  id         Int       @id @default(autoincrement())
  name       String    @unique // "worker-01" — avtomatik beriladi
  active     Boolean   @default(true) // admin yoqib/o'chiradi (8/10, 20/20...)
  status     String    @default("offline") // offline | idle | busy
  pid        Int? // band qilgan jarayon PID (pool ishlatganda)
  host       String? // qaysi mashinada ishlayapti
  currentJob String? // hozir bajarayotgan ish ("order applicant=42")
  jobsDone   Int       @default(0) // shu worker bajargan ishlar soni
  lastError  String?   @db.Text // oxirgi xato (bo'lsa)
  claimedAt  DateTime? // pool tomonidan band qilingan vaqt
  lastSeenAt DateTime? // oxirgi heartbeat vaqti
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt

  @@index([active])
  @@index([status])
}

// Tizim sozlamalari — butun tizimga BITTA yozuv (singleton, id=1). Avval bu
// qiymatlar faqat .env'da edi (PROXY_*, BOOKING_HEADLESS, timeout'lar...).
// Endi BAZADA saqlanadi va super-admin "Sozlamalar" sahifasidan tahrirlanadi.
// lib/settings.ts bu yozuvni o'qib process.env'ga yuklaydi (hydrate) — shu
// sababli mavjud kod (proxy.ts, browser.ts, booking.ts) o'zgarmaydi, faqat
// endi qiymatlar bazadan keladi. Birinchi marta yaratilganda joriy .env
// qiymatlaridan to'ldiriladi (silliq ko'chish).
model AppSettings {
  id Int @id @default(1)

  // --- Proksi (PROXY_*) ---
  proxyEnabled   Boolean @default(false) // PROXY_ENABLED
  proxyHost      String  @default("") // PROXY_HOST
  proxyPort      String  @default("") // PROXY_PORT
  proxyUser      String  @default("") // PROXY_USER
  proxyPass      String  @default("") // PROXY_PASS (maxfiy — UI'da maskalanadi)
  proxyCountries String  @default("uz,kz") // PROXY_COUNTRIES

  // --- Chrome ko'rinishi ---
  chromeHeadless Boolean @default(true) // BOOKING_HEADLESS: true=yashirin, false=ko'rinadi

  // --- Timeout'lar / urinishlar ---
  captchaTimeoutMs     Int @default(30000) // BOOKING_CAPTCHA_TIMEOUT_MS — Turnstile token kutish
  cfChallengeTimeoutMs Int @default(45000) // BOOKING_CF_CHALLENGE_TIMEOUT_MS — Cloudflare challenge kutish
  maxAttempts          Int @default(3) // ORDER_MAX_ATTEMPTS — bir bosqich uchun urinishlar
  ipRetries            Int @default(4) // BOOKING_PROXY_IP_RETRIES — IP blok bo'lsa yangi IP urinishlari

  // --- Worker'lar ---
  workerPerCpu Int @default(2) // WORKER_PER_CPU — 1 yadroga to'g'ri keladigan worker

  updatedAt DateTime @updatedAt
  updatedBy String? // oxirgi tahrirlagan super-admin (username)
}

